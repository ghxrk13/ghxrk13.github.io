---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    slug: 'llm-osec',
    title: 'llm-osec — OWASP LLM Top 10 scanner',
    blurb: 'CLI that probes a deployed LLM application for the OWASP Top 10 risks specific to LLMs (prompt injection, sensitive data leakage, insecure output handling, etc.) and produces a structured findings report.',
    tags: ['AI security', 'Python', 'Claude', 'CISSP-flavored'],
    status: 'In development',
  },
  {
    slug: 'apld-edge',
    title: 'apld-edge — algorithmic trading platform',
    blurb: 'Sqlite-backed 24/7 market-data collection daemon plus Claude-driven signal scoring and append-only decision log. Production-grade end-to-end, deployed across local and cloud infrastructure.',
    tags: ['Python', 'Claude', 'Async', 'SQLite', 'AWS'],
    status: 'Live',
  },
  {
    slug: 'dojo-n-speed',
    title: 'dojo-n-speed — LLM-augmented AppSec tooling',
    blurb: 'Production contributions to a DefectDojo fork: multi-SCM abstraction, VS Code integration, governance-aware infrastructure for compliance-sensitive environments.',
    tags: ['Django', 'Python', 'AppSec', 'LLMs in production'],
    status: 'Shipped',
  },
  {
    slug: 'flip-edge',
    title: 'flip-edge — vision-driven marketplace valuation',
    blurb: 'Claude Vision API + Playwright pipeline that ingests marketplace screenshots, extracts listing attributes, and surfaces comp pricing for resale opportunities.',
    tags: ['Claude Vision', 'Playwright', 'Python'],
    status: 'Early',
  },
];
---

<Layout title="Projects — Ian Bragg">
  <h1>Projects</h1>
  <p class="muted">A working list. Anything tagged "In development" or "Early" is actively under construction.</p>

  {projects.map((p) => (
    <a class="project-card" href={`/projects/${p.slug}/`}>
      <h3>{p.title}</h3>
      <p>{p.blurb}</p>
      <div class="tags">
        <span class="muted">{p.status}</span>
        &nbsp;·&nbsp;
        {p.tags.join(' · ')}
      </div>
    </a>
  ))}
</Layout>
