---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Ian Bragg', description = 'Senior technical leader and applied AI engineer. AI/ML, robotics, cybersecurity.' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav class="top">
      <div class="inner">
        <a class="name" href="/">Ian Bragg</a>
        <a href="/projects/">Projects</a>
        <a href="/resume/">Resume</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <a href="mailto:ghxrk13@proton.me">ghxrk13@proton.me</a>
      &nbsp;·&nbsp;
      <a href="https://www.linkedin.com/in/ian-bragg-787b8997">LinkedIn</a>
    </footer>
  </body>
</html>
